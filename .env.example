# =================================================================
#  SERVER CONFIGURATION
# =================================================================
HOST=0.0.0.0
PORT=8051
TRANSPORT=sse

# =================================================================
#  DATABASE CONNECTIONS
# =================================================================
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# Neo4j (only if USE_KNOWLEDGE_GRAPH=true)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# =================================================================
#  AI MODEL CONFIGURATION
# =================================================================
# Primary Models
CHAT_MODEL=gpt-4o-mini
CHAT_MODEL_API_KEY=your_chat_model_api_key
CHAT_MODEL_API_BASE=

EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MODEL_API_KEY=your_embedding_model_api_key
EMBEDDING_MODEL_API_BASE=
EMBEDDING_DIMENSIONS=1536

# Fallback Models
CHAT_MODEL_FALLBACK=gpt-3.5-turbo
CHAT_MODEL_FALLBACK_API_KEY=
CHAT_MODEL_FALLBACK_API_BASE=

EMBEDDING_MODEL_FALLBACK=text-embedding-3-small
EMBEDDING_MODEL_FALLBACK_API_KEY=
EMBEDDING_MODEL_FALLBACK_API_BASE=
EMBEDDING_DIMENSIONS_FALLBACK=1536

RERANKING_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# =================================================================
#  FEATURE FLAGS
# =================================================================
USE_CONTEXTUAL_EMBEDDINGS=false
USE_HYBRID_SEARCH=false
USE_AGENTIC_RAG=false
USE_RERANKING=false
USE_KNOWLEDGE_GRAPH=false
USE_CHAT_MODEL_FALLBACK=false
USE_EMBEDDING_MODEL_FALLBACK=false

# =================================================================
#  PERFORMANCE SETTINGS
# =================================================================
MAX_CRAWL_DEPTH=3
MAX_CONCURRENT_CRAWLS=10
CHUNK_SIZE=5000
MIN_CODE_BLOCK_LENGTH=1000
DEFAULT_MATCH_COUNT=5

SOURCE_SUMMARY_MAX_LENGTH=500
CONTENT_TRUNCATION_LIMIT=25000
CHUNK_BREAK_THRESHOLD=0.3
LANGUAGE_SPECIFIER_MAX_LENGTH=20

TABLE_SOURCES=sources
TABLE_CRAWLED_PAGES=crawled_pages
TABLE_CODE_EXAMPLES=code_examples

CHAT_MAX_RETRIES=3
EMBEDDING_MAX_RETRIES=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=15.0

HYBRID_SEARCH_MULTIPLIER=2

MAX_WORKERS_SUMMARY=1
MAX_WORKERS_CONTEXT=1
MAX_WORKERS_SOURCE_SUMMARY=1
SUPABASE_BATCH_SIZE=2
SUPABASE_MAX_RETRIES=3

MAX_CONCURRENT_REQUESTS=5
REQUEST_TIMEOUT=30
RATE_LIMIT_DELAY=0.5
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT_MINUTES=5
CLIENT_CACHE_TTL=3600

APPLICATION_VERSION=1.0.0
APPLICATION_NAME=mcp-crawl4ai-rag